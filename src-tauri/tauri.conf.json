{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Photoshop MVP",
  "version": "0.1.0",
  "identifier": "com.brady.photoshop",
  "build": {
    "beforeDevCommand": "node scripts/tauri-dev-server.mjs",
    "devUrl": "http://127.0.0.1:4173",
    "frontendDist": "../web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Photoshop MVP",
        "width": 1480,
        "height": 980,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
